{
  // ============================================================================
  // vault0conf — Vault0 integration config for OpenCode
  // ============================================================================
  // This config defines vault0 tool permissions and instructions per agent.
  // Merge into or reference from your main opencode.jsonc.
  //
  // Role mapping (adapt agent names to your setup):
  //   orchestrator = Task discovery, execution loop, approvals
  //   executor     = Task implementation, status updates
  //   planner      = Plan creation, subtask/dependency setup
  //   git          = Post-commit task approval
  // ============================================================================

  "$schema": "https://opencode.ai/config.json",

  "instructions": [
    "~/.config/vault0/opencode/instructions/vault0-tool-rules.md",
    "~/.config/vault0/opencode/instructions/vault0-orchestration.md",
    "~/.config/vault0/opencode/instructions/vault0-executor-workflow.md",
    "~/.config/vault0/opencode/instructions/vault0-planner-workflow.md",
    "~/.config/vault0/opencode/instructions/vault0-git-agent.md"
  ],

  "agent": {
    // Role: The Orchestrator (task discovery, execution loop, approvals)
    // 6 tools — no vault0-task-complete (cannot move to done)
    "marsellus": {
      "tools": {
        "vault0-task-add": true,
        "vault0-task-list": true,
        "vault0-task-view": true,
        "vault0-task-update": true,
        "vault0-task-move": true,
        "vault0-task-subtasks": true,
        "vault0-task-complete": false
      },
      "permission": {
        "vault0-task-add": "allow",
        "vault0-task-list": "allow",
        "vault0-task-view": "allow",
        "vault0-task-update": "allow",
        "vault0-task-move": "allow",
        "vault0-task-subtasks": "allow"
      }
    },

    // Role: The Executor (task implementation, status updates)
    // 5 tools — no add, no complete (executes tasks, doesn't create or finish them)
    "wolf": {
      "tools": {
        "vault0-task-add": false,
        "vault0-task-list": true,
        "vault0-task-view": true,
        "vault0-task-update": true,
        "vault0-task-move": true,
        "vault0-task-subtasks": true,
        "vault0-task-complete": false
      },
      "permission": {
        "vault0-task-list": "allow",
        "vault0-task-view": "allow",
        "vault0-task-update": "allow",
        "vault0-task-move": "allow",
        "vault0-task-subtasks": "allow"
      }
    },

    // Role: The Planner (plan creation, subtask/dependency setup)
    // 5 tools — no move, no complete (creates plans, doesn't change status)
    "architect": {
      "tools": {
        "vault0-task-add": true,
        "vault0-task-list": true,
        "vault0-task-view": true,
        "vault0-task-update": true,
        "vault0-task-move": false,
        "vault0-task-complete": false,
        "vault0-task-subtasks": true
      },
        "permission": {
          "bash": {
            "*": "deny",  // Deny ALL bash — architect doesn't need bash in vault0 environment
            "vault0 --version": "allow" // Except this :O
          },
          "write": {
            "*": "deny",
            ".opencode/plans/*": "deny",
            ".opencode/plans/**/*": "deny"
          },
          "edit": {
            "*": "deny",
            ".opencode/plans/*": "deny",
            ".opencode/plans/**/*": "deny"
          },
          "vault0-task-add": "allow",
          "vault0-task-list": "allow",
          "vault0-task-view": "allow",
          "vault0-task-update": "allow",
          "vault0-task-subtasks": "allow"
        }
    },

    // Role: The Git Agent (post-commit task approval)
    // 3 tools — list + view + complete for post-commit approvals
    "git": {
      "tools": {
        "vault0-task-add": false,
        "vault0-task-list": true,
        "vault0-task-view": true,
        "vault0-task-update": false,
        "vault0-task-move": false,
        "vault0-task-complete": true,
        "vault0-task-subtasks": false
      },
      "permission": {
        "vault0-task-list": "allow",
        "vault0-task-view": "allow",
        "vault0-task-complete": "allow"
      }
    }
  }
}
