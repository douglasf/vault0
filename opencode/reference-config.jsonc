// ── Reference Configuration for Per-Agent Tool Permissions ──────────
// This file shows how to configure tool permissions per agent in OpenCode.
// It is a REFERENCE ONLY — you do not need to use it for basic setup.
//
// For basic setup, run: vault0 mcp init
//
// If you want fine-grained control over which agents can use which tools,
// customize the agent entries below and add them to your opencode.json.
// Replace agent names (marsellus, wolf, vincent, etc.) with your own.
//
// Available tools:
//   task-view       View task details by ID
//   task-add        Create a new task
//   task-move       Change task status (not to done — use task-complete)
//   task-update     Update task metadata and dependencies
//   task-complete   Mark a task as done
//   task-list       Query tasks with filters
//   task-subtasks   Get subtasks for a parent task

{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "vault0": {
      "type": "local",
      "command": ["vault0", "mcp", "serve"],
      "enabled": true
    }
  },

  "agent": {
    // Role: Orchestrator — discovers tasks, delegates work, tracks progress
    "marsellus": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": true,
        "vault0_task-list": true,
        "vault0_task-move": true,
        "vault0_task-update": true,
        "vault0_task-subtasks": true,
        "vault0_task-complete": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-add": "allow",
        "vault0_task-list": "allow",
        "vault0_task-move": "allow",
        "vault0_task-update": "allow",
        "vault0_task-subtasks": "allow"
      }
    },

    // Role: Executor — implements tasks, updates status
    "wolf": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-move": true,
        "vault0_task-update": true,
        "vault0_task-complete": true,
        "vault0_task-add": false,
        "vault0_task-list": false,
        "vault0_task-subtasks": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-move": "allow",
        "vault0_task-update": "allow",
        "vault0_task-complete": "allow"
      }
    },

    // Role: Investigator — read-only access
    "vincent": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": false,
        "vault0_task-list": false,
        "vault0_task-move": false,
        "vault0_task-update": false,
        "vault0_task-subtasks": false,
        "vault0_task-complete": false
      },
      "permission": {
        "vault0_task-view": "allow"
      }
    },

    // Role: Planner — creates tasks and sets up dependencies
    "architect": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": true,
        "vault0_task-update": true,
        "vault0_task-list": false,
        "vault0_task-move": false,
        "vault0_task-subtasks": false,
        "vault0_task-complete": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "vault0 --version": "allow"
        },
        "write": {
          "*": "deny",
          ".opencode/plans/*": "deny",
          ".opencode/plans/**/*": "deny"
        },
        "edit": {
          "*": "deny",
          ".opencode/plans/*": "deny",
          ".opencode/plans/**/*": "deny"
        },
        "vault0_task-view": "allow",
        "vault0_task-add": "allow",
        "vault0_task-update": "allow"
      }
    },

    // Role: Coordinator — read-only access
    "jules": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": false,
        "vault0_task-list": false,
        "vault0_task-move": false,
        "vault0_task-update": false,
        "vault0_task-subtasks": false,
        "vault0_task-complete": false
      },
      "permission": {
        "vault0_task-view": "allow"
      }
    },

    // Role: Git Agent — completes tasks after commits
    "git": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-list": true,
        "vault0_task-complete": true,
        "vault0_task-add": false,
        "vault0_task-move": false,
        "vault0_task-update": false,
        "vault0_task-subtasks": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-list": "allow",
        "vault0_task-complete": "allow"
      }
    }
  }
}
