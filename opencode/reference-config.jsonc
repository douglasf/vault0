// ── Reference Configuration for Per-Agent Tool Permissions ──────────
// This file shows how to configure tool permissions per agent in OpenCode.
// It is a REFERENCE ONLY — you do not need to use it for basic setup.
//
// For basic setup, run: vault0 mcp init
//
// If you want fine-grained control over which agents can use which tools,
// customize the agent entries below and add them to your opencode.json.
// Replace agent names (marsellus, wolf, vincent, etc.) with your own.

{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "vault0": {
      "type": "local",
      "command": ["vault0", "mcp", "serve"],
      "enabled": true
    }
  },

  "agent": {
    // Role: The Orchestrator (task discovery, execution loop, approvals)
    // Uses orchestrator-specific variants for list, move, subtasks, and planner variant for add
    "marsellus": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add-planner": true,
        "vault0_task-list-orchestrator": true,
        "vault0_task-move-orchestrator": true,
        "vault0_task-update": true,
        "vault0_task-subtasks-orchestrator": true,
        "vault0_task-complete": false,
        "vault0_task-complete-git": false,
        "vault0_task-add": false,
        "vault0_task-list": false,
        "vault0_task-move": false,
        "vault0_task-move-executor": false,
        "vault0_task-subtasks": false,
        "vault0_task-update-planner": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-add-planner": "allow",
        "vault0_task-list-orchestrator": "allow",
        "vault0_task-move-orchestrator": "allow",
        "vault0_task-update": "allow",
        "vault0_task-subtasks-orchestrator": "allow"
      }
    },

    // Role: The Executor (task implementation, status updates)
    // Uses executor-specific move variant
    "wolf": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-move-executor": true,
        "vault0_task-update": true,
        "vault0_task-complete": true,
        "vault0_task-add": false,
        "vault0_task-add-planner": false,
        "vault0_task-list": false,
        "vault0_task-list-orchestrator": false,
        "vault0_task-move": false,
        "vault0_task-move-orchestrator": false,
        "vault0_task-subtasks": false,
        "vault0_task-subtasks-orchestrator": false,
        "vault0_task-complete-git": false,
        "vault0_task-update-planner": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-move-executor": "allow",
        "vault0_task-update": "allow",
        "vault0_task-complete": "allow"
      }
    },

    // Role: The Investigator (read-only, task-view only)
    "vincent": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": false,
        "vault0_task-add-planner": false,
        "vault0_task-list": false,
        "vault0_task-list-orchestrator": false,
        "vault0_task-move": false,
        "vault0_task-move-executor": false,
        "vault0_task-move-orchestrator": false,
        "vault0_task-update": false,
        "vault0_task-update-planner": false,
        "vault0_task-subtasks": false,
        "vault0_task-subtasks-orchestrator": false,
        "vault0_task-complete": false,
        "vault0_task-complete-git": false
      },
      "permission": {
        "vault0_task-view": "allow"
      }
    },

    // Role: The Planner (plan creation, subtask/dependency setup)
    // Uses planner-specific variants for add and update
    "architect": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add-planner": true,
        "vault0_task-update-planner": true,
        "vault0_task-add": false,
        "vault0_task-list": false,
        "vault0_task-list-orchestrator": false,
        "vault0_task-move": false,
        "vault0_task-move-executor": false,
        "vault0_task-move-orchestrator": false,
        "vault0_task-update": false,
        "vault0_task-subtasks": false,
        "vault0_task-subtasks-orchestrator": false,
        "vault0_task-complete": false,
        "vault0_task-complete-git": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "vault0 --version": "allow"
        },
        "write": {
          "*": "deny",
          ".opencode/plans/*": "deny",
          ".opencode/plans/**/*": "deny"
        },
        "edit": {
          "*": "deny",
          ".opencode/plans/*": "deny",
          ".opencode/plans/**/*": "deny"
        },
        "vault0_task-view": "allow",
        "vault0_task-add-planner": "allow",
        "vault0_task-update-planner": "allow"
      }
    },

    // Role: The Coordinator (read-only, task-view only)
    "jules": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-add": false,
        "vault0_task-add-planner": false,
        "vault0_task-list": false,
        "vault0_task-list-orchestrator": false,
        "vault0_task-move": false,
        "vault0_task-move-executor": false,
        "vault0_task-move-orchestrator": false,
        "vault0_task-update": false,
        "vault0_task-update-planner": false,
        "vault0_task-subtasks": false,
        "vault0_task-subtasks-orchestrator": false,
        "vault0_task-complete": false,
        "vault0_task-complete-git": false
      },
      "permission": {
        "vault0_task-view": "allow"
      }
    },

    // Role: The Git Agent (post-commit task approval)
    // Uses git-specific complete variant
    "git": {
      "tools": {
        "vault0_task-view": true,
        "vault0_task-list": true,
        "vault0_task-complete-git": true,
        "vault0_task-add": false,
        "vault0_task-add-planner": false,
        "vault0_task-list-orchestrator": false,
        "vault0_task-move": false,
        "vault0_task-move-executor": false,
        "vault0_task-move-orchestrator": false,
        "vault0_task-update": false,
        "vault0_task-update-planner": false,
        "vault0_task-subtasks": false,
        "vault0_task-subtasks-orchestrator": false,
        "vault0_task-complete": false
      },
      "permission": {
        "vault0_task-view": "allow",
        "vault0_task-list": "allow",
        "vault0_task-complete-git": "allow"
      }
    }
  }
}
